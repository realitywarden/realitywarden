{
  "manifest_version": 1,
  "action_id": "inspect_then_capture",
  "display_name": { "zh": "检查后拍摄", "en": "Inspect then capture" },
  "device_type": "camera_sensor",
  "safety": {
    "declared_risk": "low",
    "required_sensors": [],
    "envelope": { "max_speed": "slow", "max_force": "low" }
  },
  "steps": [
    { "action": "read_sensor", "target": "camera_view", "speed": "slow" },
    { "action": "capture_frame", "target": "camera_view", "speed": "slow" }
  ]
}
