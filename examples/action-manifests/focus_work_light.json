{
  "manifest_version": 1,
  "action_id": "focus_work_light",
  "display_name": { "zh": "专注工作灯", "en": "Focus work light" },
  "device_type": "smart_light",
  "safety": {
    "declared_risk": "low",
    "required_sensors": [],
    "envelope": { "max_speed": "slow", "max_force": "low" }
  },
  "steps": [
    { "action": "set_light", "target": "lamp", "speed": "slow", "value": true },
    { "action": "set_brightness", "target": "lamp", "speed": "slow", "value": 55 },
    { "action": "set_color", "target": "lamp", "speed": "slow", "value": "warm_white" }
  ]
}
