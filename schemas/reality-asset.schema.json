{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openreality.studio/schemas/reality-asset.schema.json",
  "title": "Open Reality Asset Package",
  "type": "object",
  "required": [
    "assetId",
    "name",
    "version",
    "vendor",
    "description",
    "deviceManifest",
    "capabilityContracts",
    "worldModelAssumptions",
    "adapterBoundary",
    "examplePrompts",
    "validationRules",
    "supportLevel",
    "safetyNotes",
    "tags"
  ],
  "properties": {
    "assetId": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "vendor": { "type": "string", "minLength": 1 },
    "description": { "type": "string", "minLength": 1 },
    "supportLevel": {
      "type": "string",
      "enum": ["simulation_only", "read_only", "coming_soon", "unsupported"]
    },
    "deviceManifest": {
      "type": "object",
      "required": ["deviceId", "displayName", "category", "supportLevel", "capabilities", "adapter"],
      "properties": {
        "deviceId": { "type": "string", "minLength": 1 },
        "displayName": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "supportLevel": {
          "type": "string",
          "enum": ["simulation_only", "read_only", "coming_soon", "unsupported"]
        },
        "capabilities": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/capabilityContract" }
        },
        "adapter": {
          "type": "object",
          "required": ["simulationAdapter", "realAdapterEnabled"],
          "properties": {
            "simulationAdapter": { "type": "string" },
            "realAdapterEnabled": { "const": false }
          }
        }
      }
    },
    "capabilityContracts": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/capabilityContract" }
    },
    "worldModelAssumptions": {
      "type": "object",
      "required": ["objects", "zones", "confidence"]
    },
    "adapterBoundary": {
      "type": "object",
      "required": [
        "simulationAdapterAvailable",
        "readOnlyAdapterAvailable",
        "realAdapterEnabled",
        "adapterMode",
        "taskDslIsHardwareCommand",
        "notes"
      ],
      "properties": {
        "simulationAdapterAvailable": { "type": "boolean" },
        "readOnlyAdapterAvailable": { "type": "boolean" },
        "realAdapterEnabled": { "const": false },
        "adapterMode": {
          "type": "string",
          "enum": ["simulation_only", "read_only", "real_disabled"]
        },
        "taskDslIsHardwareCommand": { "const": false },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "examplePrompts": {
      "type": "object",
      "anyOf": [
        { "required": ["supported"] },
        { "required": ["unsupported"] },
        { "required": ["ambiguous"] }
      ],
      "properties": {
        "supported": { "type": "array", "items": { "type": "string" } },
        "unsupported": { "type": "array", "items": { "type": "string" } },
        "unsafe": { "type": "array", "items": { "type": "string" } },
        "ambiguous": { "type": "array", "items": { "type": "string" } }
      }
    },
    "validationRules": { "type": "object" },
    "safetyNotes": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "$defs": {
    "capabilityContract": {
      "type": "object",
      "required": ["id", "name", "category", "description", "executionPermission"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "description": { "type": "string" },
        "executionPermission": {
          "type": "string",
          "enum": ["simulation_only", "read_only", "ask_human", "blocked"]
        }
      }
    }
  }
}
